{
  "manifest_version": 3,
  "name": "B.A.H.M.S. User Info",
  "description": "Display BAHMS stats in Twitch user cards",
  "version": "1.0.0",
  "permissions": ["storage"],
  "action": { "default_popup": "popup.html", "default_title": "B.A.H.M.S. User Info", "default_icon": "assets/logo_128x128.png" },
  "host_permissions": ["https://*.twitch.tv/*", "https://api.bahms.org/*"],
  "content_scripts": [
    {
      "matches": ["https://*.twitch.tv/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "48": "assets/logo_48x48.png",
    "64": "assets/logo_64x64.png",
    "128": "assets/logo_128x128.png"
  }
}
